<h1>Kategori: <%= h @category["name"] %></h1>

<div class="posts-list">
  <% if @posts && @posts.any? %>
    <% @posts.each do |post| %>
      <div style="border: 1px solid #ccc; padding: 10px; margin-bottom: 10px;">
        <h3>
          Tråd:<a href="/threads/<%= post['thread_id'] %>"><%= h post['title'] %></a>
        </h3>
        <p><%= h post['content'] %></p>
        <small>Postat av: <%= h post['username'] %></small>
      </div>
    <% end %>
  <% else %>
    <p>Inga inlägg i denna kategori än.</p>
  <% end %>
</div>

<br>
<a href="/categories/<%= @category["id"] %>/threads/new">
  ➕ Skapa ny tråd
</a>
<br><br>
<a href="/">⬅ Tillbaka</a>