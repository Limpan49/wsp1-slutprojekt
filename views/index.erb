<main class="container">

  <div class="top-bar">
    <% if logged_in? %>
      👋 Inloggad som <strong><%= h current_user["username"] %></strong>
      <a href="/logout">Logga ut</a>
      <a href="/users/tabort">Ta bort / uppdatera konto</a>   
    <% else %>
      <a href="/login">Logga in</a> |
      <a href="/registrera">Registrera</a>
      <a href="/users/tabort">Ta bort / uppdatera konto</a>    
    <% end %>
  </div>

  <h2>Forumets Kategorier</h2>

  <% if @categories.any? %>
    <% @categories.each do |category| %>
      <div class="category-card">
        <h3>
          <a href="/categories/<%= category["id"] %>">
            <%= h category["name"] %>
          </a>
        </h3>

        <% if logged_in? %>
          <a class="new-thread-btn"
             href="/categories/<%= category["id"] %>/threads/new">
             ➕ Skapa ny tråd
          </a>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p>Inga kategorier ännu.</p>
  <% end %>

</main>
